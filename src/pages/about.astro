---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Testimonial from "../components/Testimonial.astro";

// Sample testimonial data
const testimonialData = [
  {
    name: "Naomi Pryzant",
    text: "I’ve been getting my hair cut by Kasey for a few years now and she really is a curly hair expert. I trust her wholeheartedly with my hair.",
    image: "naomi.png",
    rating: 5,
    date: "April 18, 2024",
  },
  {
    name: "Charla Custis",
    text: "Kasey has been my exclusive hair stylist for over 5 years. When you find someone who gets you then you stick with them. I am always 100% satisfied with my haircuts and highlights. She does a great job covering the gray and I always feel like a new woman every time I step away from her chair.",
    image: "charla.png",
    rating: 5,
    date: "May 6, 2024",
  },
  {
    name: "Christina Katzerman",
    text: "Kasey has been doing my hair for over a year now and I’ve never received as many compliments on my hair as I do now! I love getting my hair done by her and I definitely recommend going to her!",
    image: "christina.png",
    rating: 5,
    date: "March 21, 2024",
  },
];
---

<Layout />
<Nav />
<div class="heading">
  <div class="heading-text">
  <h1>UNLOCK THE MAGIC IN YOUR HAIR.</h1>
</div>
</div>
<main>
    <div class="text-wrapper">
      <h2>MEET KASEY</h2>
      <p>
        Located in historic downtown Colorado Springs, MYSTIC MANES offers big
        city experience in a relaxed salon. Kasey Esclavon is a master of her
        craft—with specialized areas of expertise—and educates every client on
        how to maintain their look at home. She delivers consistent results and
        personalized service in a welcoming atmosphere.
      </p>
    </div>
    <div class="image-wrapper">
      <img src="kasey.jpg" alt="Image 1" />
      <h3>KASEY ESCLAVON</h3>
      <p>Owner & Stylist</p>
    </div>
  
  
</main>

<Footer />

<style>
  main {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    justify-content: center;
    align-items: center;
    margin-top: 2rem;
    padding: 1rem;
  }

  .heading {
    display: flex;
    background-image: url("hairbg.jpg");
    background-size: cover;
    background-position: 10% 60%;
    max-width: 100%;
    min-height: 20rem;
    margin-top: 6rem;
    align-items: center;
  }

  .heading-text {
    line-height: 1.1;
    margin: 0 auto;
    padding-inline: 1rem;
    max-width: 1200px;
    color: white;
  }

  .heading-text h1{
    font-size: clamp(3.75rem, 6vw, 4.5rem);
    font-family: "Poppins", sans-serif;
    letter-spacing: 0.1em;
  }

  .split-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    margin: 0 auto;
    margin-bottom: 5%;
    gap: 1rem;
  }

  .text-wrapper {
    max-width: 100%;
    font-size: clamp(1.5rem, 1.25vw, 2.5rem);
    text-align: center;
  }

  .text-wrapper h2 {
    font-size: clamp(1rem, 1.25vw, 1.5rem);
    font-family: "Poppins", sans-serif;
    letter-spacing: 0.1em;
    padding: 1rem;
  }

  .text-wrapper p {
    font-size: clamp(1.25rem, 1.35vw, 1.5rem);
  }

  .image-wrapper {
    max-width: 100%;
    
    margin-block: 3rem;
    font-family: "Poppins", sans-serif;
  }

  .image-wrapper img {
    max-width: 100%;
    height: auto;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    padding-bottom: 1rem;
  }

  @media (max-width: 767px) {
    .split-wrapper {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }

    .text-wrapper {
      max-width: 100%;
      text-align: center;
    }

    .image-wrapper {
      max-width: 100%;
    }
  }
</style>
